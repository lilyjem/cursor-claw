{
  "name": "cursor-claw",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram <-> Cursor SDK bridge — drive Cursor agents on your local repos from your phone.",
  "type": "module",
  "license": "MIT",
  "author": "Jem Li",
  "homepage": "https://github.com/lilyjem/cursor-claw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lilyjem/cursor-claw.git"
  },
  "bugs": {
    "url": "https://github.com/lilyjem/cursor-claw/issues"
  },
  "keywords": [
    "cursor",
    "cursor-sdk",
    "telegram",
    "telegram-bot",
    "agent",
    "ai",
    "automation",
    "personal-assistant",
    "remote-coding",
    "wechat",
    "messenger",
    "grammy"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "bin": {
    "cursor-claw": "./dist/bin/cursor-claw.js",
    "claw-attach-image": "./dist/tools/attach-image.js",
    "claw-attach-file": "./dist/tools/attach-file.js"
  },
  "scripts": {
    "dev": "tsx watch src/bin/cursor-claw.ts",
    "build": "tsup",
    "start": "node dist/bin/cursor-claw.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "audit:security": "node scripts/audit-security.mjs"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "grammy": "^1.42.0",
    "mime-types": "^3.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "3.25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "//security_overrides": "F-03 修复：把 install-time 路径穿越风险的传递依赖链全部升级到当前 advisory 已修复版本（tar 7.5.11+ / node-gyp 10.3.1+ / cacache 18 / make-fetch-happen 13 / http-proxy-agent 7 / @tootallnate/once 2）。注意：undici 故意不在此列，F-02 已标 Accepted-Risk，等待 @cursor/sdk → @connectrpc/connect-node 上游升级后再处理。",
  "overrides": {
    "tar": "^7.5.11",
    "cacache": "^18.0.4",
    "make-fetch-happen": "^13.0.1",
    "node-gyp": "^10.3.1",
    "http-proxy-agent": "^7.0.2",
    "@tootallnate/once": "npm:@tootallnate/once@2.0.0"
  }
}
